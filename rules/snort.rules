# ----------------
# LOCAL RULES (Snort 2.9)
# ----------------

########################
# ICMP RULES
########################

alert icmp any any -> $HOME_NET any (msg:"ICMP Echo Request detected"; itype:8; sid:1000001; rev:1;)
alert icmp any any -> $HOME_NET any (msg:"ICMP Echo Reply detected"; itype:0; sid:1000002; rev:1;)
alert icmp any any -> $HOME_NET any (msg:"ICMP request with unusual size"; itype:8; dsize:>1000; sid:1000003; rev:1;)
alert icmp any any -> $HOME_NET any (msg:"ICMP Destination unreachable"; itype:3; sid:1000004; rev:1;)
alert icmp any any -> $HOME_NET any (msg:"ICMP Timestamp request detected"; itype:13; sid:1000005; rev:1;)
alert icmp any any -> $HOME_NET any (msg:"ICMP Echo Request detected"; itype:8; sid:1000001; rev:1;)

########################
# TCP SERVICE RULES
########################

alert tcp any any -> any 22 (msg:"Multiple SSH connection attempts detected"; flags:S; threshold:type both, track by_src, count 5, seconds 60; sid:1000007; rev:1;)
alert tcp any any -> any 23 (msg:"TCP connection attempt to Telnet (port 23)"; flags:S; sid:1000008; rev:1;)
alert tcp any any -> any 21 (msg:"TCP connection attempt to the FTP service"; flags:S; sid:1000009; rev:1;)

########################
# MQTT / IOT RULES
########################

alert tcp any any -> any 1883 (msg:"MQTT traffic detected"; sid:2000001; rev:1;)
alert tcp any any -> any 1883 (msg:"High-rate MQTT traffic (possible IoT flood)"; threshold:type both, track by_src, count 20, seconds 10; sid:2000002; rev:1;)

########################

alert tcp any any -> $HOME_NET 80 (msg:"Possible TCP SYN flood or scan"; flags:S; detection_filter:track by_src, count 50, seconds 10; sid:1000020; rev:1;)

